---
import { SOCIAL, SITE } from "../consts";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-motto">
      <span class="footer-mark">A·S·K</span>
      <span class="footer-mark-sep">·</span>
      <span class="footer-mark-text">{SITE.motto}</span>
    </div>

    <div class="footer-row">
      <div class="footer-credit">
        <p>
          {SITE.name} · <span class="footer-tag">stories · essays · code · log</span>
        </p>
      </div>

      <div class="footer-links">
        {SOCIAL.map((s) => (
          <a
            href={s.url}
            target={s.url.startsWith("http") ? "_blank" : undefined}
            rel={s.url.startsWith("http") ? "noopener noreferrer" : undefined}
            class="footer-social"
          >
            {s.name}
          </a>
        ))}
        <a
          href="https://github.com/arunsetty/arunsetty.github.io"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social footer-source"
        >
          View source
        </a>
      </div>
    </div>

    <div class="footer-meta">
      <span class="footer-year">© {year}</span>
      <span class="footer-sep">·</span>
      <span class="footer-built">Astro · Bun · GitHub Pages</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 48px 24px 32px;
    border-top: 1px solid var(--border-color);
    margin-top: 64px;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .footer-motto {
    padding: 16px 0 20px;
    border-bottom: 1px solid var(--rule-color);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 12px;
  }

  .footer-mark {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.04em;
  }

  .footer-mark-sep {
    color: var(--accent-primary);
  }

  .footer-mark-text {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    color: var(--text-secondary);
  }

  .footer-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 24px;
  }

  .footer-credit p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .footer-tag {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    margin-left: 8px;
  }

  .footer-links {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .footer-social {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .footer-social:hover {
    color: var(--accent-primary);
  }

  .footer-source::before {
    content: "→ ";
    color: var(--accent-primary);
  }

  .footer-meta {
    color: var(--text-quiet);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
  }

  .footer-sep {
    margin: 0 8px;
    opacity: 0.5;
  }
</style>
