---
import { SOCIAL, SITE } from "../consts";
---

<footer class="footer">
  <div class="footer-inner">
    <!-- Cinematic footer -->
    <div class="footer-cinematic">
      <div class="footer-links">
        {SOCIAL.map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social"
            aria-label={s.name}
          >
            {s.name}
          </a>
        ))}
      </div>
      <div class="footer-info">
        <p class="footer-credit">
          Built by <span class="gradient-text">{SITE.name}</span>
        </p>
        <p class="footer-year">&copy; {new Date().getFullYear()}</p>
      </div>
    </div>

    <!-- Terminal footer -->
    <div class="footer-terminal">
      <div class="terminal-status-bar">
        <span class="terminal-status-item">
          <span class="terminal-label">user</span>@<span class="terminal-value">arun</span>
        </span>
        <span class="terminal-divider">|</span>
        <span class="terminal-status-item">
          <span class="terminal-label">pid</span>=<span class="terminal-value">{new Date().getFullYear()}</span>
        </span>
        <span class="terminal-divider">|</span>
        <span class="terminal-status-item">
          <span class="terminal-label">uptime</span>=<span class="terminal-value">8y+</span>
        </span>
        <span class="terminal-divider">|</span>
        {SOCIAL.slice(0, 3).map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            class="terminal-link"
          >
            {s.icon}
          </a>
        ))}
      </div>
      <div class="terminal-exit">
        <span class="terminal-muted">// EOF — built with astro + caffeine</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 48px 24px;
    border-top: 1px solid var(--border-color);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Cinematic footer */
  .footer-cinematic {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-social {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-social:hover {
    color: var(--accent-primary);
  }

  .footer-info {
    text-align: center;
  }

  .footer-credit {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: 0 0 4px;
  }

  .footer-year {
    color: var(--text-muted);
    font-size: 0.75rem;
    margin: 0;
    font-family: var(--font-mono);
  }

  /* Terminal footer — hidden by default */
  .footer-terminal {
    display: none;
  }

  /* Theme switching */
  :global([data-theme="terminal"]) .footer-cinematic {
    display: none;
  }

  :global([data-theme="terminal"]) .footer-terminal {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  :global([data-theme="terminal"]) .footer {
    border-top-color: rgba(0, 255, 65, 0.3);
    padding: 24px;
  }

  .terminal-status-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .terminal-label {
    color: #009922;
  }

  .terminal-value {
    color: #00ff41;
  }

  .terminal-divider {
    color: rgba(0, 255, 65, 0.2);
  }

  .terminal-link {
    color: #009922;
    text-decoration: none;
    transition: color 0.2s;
    margin-left: 4px;
  }

  .terminal-link:hover {
    color: #00ff41;
    text-shadow: 0 0 8px rgba(0, 255, 65, 0.5);
  }

  .terminal-exit {
    text-align: center;
    margin-top: 8px;
  }

  .terminal-muted {
    color: #009922;
    opacity: 0.6;
  }

  .terminal-status-item {
    color: #00cc33;
  }
</style>
