---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  slug: string;
}

const { title, description, pubDate, tags = [], slug } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<!-- Cinematic card -->
<a href={`/thoughts/${slug}`} class="blog-card glass-card cinematic-card">
  <div class="blog-card-meta">
    <time>{formattedDate}</time>
    {tags.length > 0 && (
      <div class="blog-card-tags">
        {tags.map((tag) => (
          <span class="blog-tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
  <h3 class="blog-card-title">{title}<span class="arrow">&rarr;</span></h3>
  <p class="blog-card-desc">{description}</p>
</a>

<!-- Terminal card -->
<a href={`/thoughts/${slug}`} class="terminal-card">
  <div class="terminal-card-row">
    <span class="terminal-perms">-rw-r--r--</span>
    <span class="terminal-date">{formattedDate}</span>
    <span class="terminal-filename">{slug}.md</span>
  </div>
  <div class="terminal-card-comment"># {title}</div>
  {tags.length > 0 && (
    <div class="terminal-card-tags">
      {tags.map((tag) => (
        <span class="terminal-tag">[{tag}]</span>
      ))}
    </div>
  )}
</a>

<style>
  .blog-card {
    display: block;
    padding: 28px;
    text-decoration: none;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .blog-card-meta time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .blog-card-tags {
    display: flex;
    gap: 6px;
  }

  .blog-tag {
    padding: 1px 8px;
    border-radius: 4px;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--accent-primary);
    border: 1px solid var(--border-color);
  }

  .blog-card-title {
    font-size: 1.2rem;
    color: var(--text-primary);
    margin: 0 0 8px;
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .arrow {
    display: inline-block;
    margin-left: 8px;
    font-size: 0.9rem;
    transition: transform 0.3s ease;
  }

  .blog-card:hover .arrow {
    transform: translateX(6px);
  }

  .blog-card:hover .blog-card-title {
    color: var(--accent-primary);
  }

  .blog-card-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Terminal card — hidden by default */
  .terminal-card {
    display: none;
  }

  :global([data-theme="terminal"]) .cinematic-card {
    display: none;
  }

  :global([data-theme="terminal"]) .terminal-card {
    display: block;
    padding: 14px 20px;
    text-decoration: none;
    font-family: var(--font-mono);
    background: rgba(0, 255, 65, 0.03);
    border: 1px solid rgba(0, 255, 65, 0.1);
    border-radius: 0;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  :global([data-theme="terminal"]) .terminal-card:hover {
    border-color: rgba(0, 255, 65, 0.4);
    box-shadow: 0 0 20px rgba(0, 255, 65, 0.1);
  }

  .terminal-card-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .terminal-perms {
    color: #009922;
    font-size: 0.7rem;
  }

  .terminal-date {
    color: #009922;
    font-size: 0.7rem;
  }

  .terminal-filename {
    color: #00ff41;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .terminal-card-comment {
    color: #00cc33;
    font-size: 0.8rem;
    line-height: 1.6;
    margin-bottom: 8px;
    padding-left: 4px;
  }

  .terminal-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .terminal-tag {
    font-size: 0.65rem;
    color: #009922;
    border: 1px solid rgba(0, 255, 65, 0.15);
    padding: 1px 6px;
  }
</style>
