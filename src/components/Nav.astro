---
import { NAV_LINKS } from "../consts";

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(`${href}/`);
---

<nav class="nav" transition:persist>
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-current={pathname === "/" ? "page" : undefined}>
      <span class="nav-logo-mark">A<span class="nav-logo-dot">·</span>S<span class="nav-logo-dot">·</span>K</span>
    </a>

    <div class="nav-links">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${isActive(link.href) ? "is-active" : ""}`}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.name}
        </a>
      ))}
    </div>

    <button class="mobile-menu-btn" aria-label="Toggle menu">
      <span class="hamburger"></span>
    </button>
  </div>

  <div class="mobile-menu">
    {NAV_LINKS.map((link) => (
      <a
        href={link.href}
        class={`mobile-link ${isActive(link.href) ? "is-active" : ""}`}
        aria-current={isActive(link.href) ? "page" : undefined}
      >
        {link.name}
      </a>
    ))}
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 24px;
    background: rgba(245, 239, 225, 0.82);
    backdrop-filter: blur(14px) saturate(115%);
    -webkit-backdrop-filter: blur(14px) saturate(115%);
    border-bottom: 1px solid var(--border-color);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-display);
    text-decoration: none;
    font-size: 1rem;
    color: var(--text-primary);
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .nav-logo-mark {
    color: var(--text-primary);
    font-weight: 600;
    font-feature-settings: "ss01";
  }

  .nav-logo-dot {
    color: var(--accent-primary);
    font-weight: 400;
    margin: 0 0.04em;
  }

  .nav-links {
    display: flex;
    gap: 28px;
  }

  .nav-link {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.18s ease;
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent-primary);
    transition: width 0.18s ease, height 0.18s ease;
  }

  .nav-link:hover { color: var(--accent-primary); }
  .nav-link:hover::after { width: 100%; }

  .nav-link.is-active {
    color: var(--accent-primary);
    font-weight: 500;
  }
  .nav-link.is-active::after {
    width: 100%;
    height: 2px;
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .hamburger {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text-primary);
    position: relative;
    transition: all 0.18s ease;
  }

  .hamburger::before, .hamburger::after {
    content: "";
    position: absolute;
    width: 20px;
    height: 1.5px;
    background: var(--text-primary);
    transition: all 0.18s ease;
  }
  .hamburger::before { top: -6px; }
  .hamburger::after { bottom: -6px; }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 24px;
    gap: 14px;
  }

  .mobile-link {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    padding: 6px 0;
  }

  .mobile-link.is-active { color: var(--accent-primary); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .mobile-menu-btn { display: block; }
    .mobile-menu.open { display: flex; }
  }
</style>

<script>
  function updateActiveNav() {
    const pathname = window.location.pathname.replace(/\/+$/, "") || "/";
    const isActive = (href: string) =>
      href === "/"
        ? pathname === "/"
        : pathname === href || pathname.startsWith(`${href}/`);

    document.querySelectorAll<HTMLAnchorElement>(".nav-link, .mobile-link").forEach((link) => {
      const href = link.getAttribute("href");
      if (!href) return;
      const active = isActive(href);
      link.classList.toggle("is-active", active);
      if (active) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    // Recompute active state, nav is `transition:persist` so the
    // server-rendered class doesn't update across view transitions.
    updateActiveNav();

    const btn = document.querySelector(".mobile-menu-btn");
    const menu = document.querySelector(".mobile-menu");

    btn?.addEventListener("click", () => {
      menu?.classList.toggle("open");
    });

    document.querySelectorAll(".mobile-link").forEach((link) => {
      link.addEventListener("click", () => {
        menu?.classList.remove("open");
      });
    });
  });
</script>
