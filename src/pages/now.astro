---
import BaseLayout from "../layouts/BaseLayout.astro";
import { NOW_UPDATED } from "../consts";
---

<BaseLayout title="Now | Arun Setty" description="What I'm currently doing and thinking about.">
  <article class="now">
    <div class="container narrow">
      <header class="now-header">
        <span class="eyebrow">Now</span>
        <h1 class="now-title">What I'm doing now</h1>
        <p class="now-meta">Last updated: {NOW_UPDATED}</p>
      </header>

      <div class="now-rule"></div>

      <div class="prose">
        <h2>Building</h2>
        <p>
          Working at <a href="https://brokenatom.io" target="_blank" rel="noopener noreferrer">Broken</a> as a software developer, building the core no-code platform.
          Focused on making application creation accessible to people who shouldn't have to learn how to code to ship something useful.
        </p>

        <h2>Learning</h2>
        <p>
          Diving deeper into systems design, distributed architecture, and the
          intersection of AI with developer tooling. Also picking at the
          philosophy of mind and what consciousness might mean for systems.
        </p>

        <h2>Reading</h2>
        <p>
          Various texts on philosophy, technology, and decision-making — the
          specifics will live here once I get around to listing them. Drop me
          a note if you want recommendations in the meantime.
        </p>

        <h2>Thinking about</h2>
        <ul>
          <li>The future of no-code and what it means for who gets to build software</li>
          <li>How stoic philosophy applies to making products</li>
          <li>The relationship between constraints and creativity in engineering</li>
        </ul>

        <p class="now-note">
          This is a <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now page</a> — a snapshot of what I'm focused on at this point in my life.
        </p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .now {
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .now-header {
    margin-bottom: 28px;
  }

  .now-title {
    font-family: var(--font-sans);
    font-size: clamp(2.2rem, 5.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 12px 0 16px;
    color: var(--text-primary);
  }

  .now-meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0;
    letter-spacing: 0.05em;
  }

  .now-rule {
    height: 1px;
    background: var(--rule-color);
    margin: 32px 0;
  }

  .now-note {
    margin-top: 56px !important;
    padding-top: 24px;
    border-top: 1px solid var(--rule-color);
    font-size: 0.92rem !important;
    color: var(--text-muted) !important;
    font-style: italic;
  }
</style>
