---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.tsx";
import {
  FeaturedWorkSection,
  SkillsFlowSection,
  StatsSection,
  ExperiencePreview,
  ThoughtsTeaser,
} from "../components/HomeSections.tsx";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order)
  .filter((p) => p.data.featured)
  .map((p) => ({
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    slug: p.slug,
    featured: p.data.featured,
  }));
---

<BaseLayout
  title="Arun Setty | Fullstack Developer & Product Architect"
  description="Fullstack developer and product architect. Building Broken, an alum of Hotstar and Foxsense, IIT Bombay graduate. Developer, philosopher, builder."
>
  <!-- Hero with staggered text animation -->
  <Hero client:load />

  <!-- Stats counter -->
  <StatsSection client:load />

  <!-- Featured Work -->
  <FeaturedWorkSection client:load projects={projects} />

  <!-- Skills -->
  <SkillsFlowSection client:load />

  <!-- Experience preview -->
  <ExperiencePreview client:load />

  <!-- Thoughts teaser -->
  <ThoughtsTeaser client:load />
</BaseLayout>
