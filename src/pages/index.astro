---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.tsx";
import { RecentThoughts, CurrentlyBuilding } from "../components/HomeSections.tsx";
import { getCollection } from "astro:content";

const allThoughts = (await getCollection("thoughts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const recent = allThoughts.slice(0, 4).map((p, i) => ({
  title: p.data.title,
  description: p.data.description,
  pubDate: p.data.pubDate,
  slug: p.slug,
  number: allThoughts.length - i,
}));

const featured = (await getCollection("projects"))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3)
  .map((p) => ({
    title: p.data.title,
    description: p.data.description,
    tags: p.data.tags,
    slug: p.slug,
    duration: p.data.duration,
  }));
---

<BaseLayout
  title="Arun Setty | Software developer & essayist"
  description="Software developer building Broken (no-code platform). Essays at Ephemeral Thoughts on decisions, systems, and craft. IIT Bombay alum, eight years in the industry."
>
  <Hero />
  <RecentThoughts thoughts={recent} total={allThoughts.length} />
  <CurrentlyBuilding projects={featured} />
</BaseLayout>
