---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { THOUGHTS } from "../../consts";

const posts = (await getCollection("thoughts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const total = posts.length;
const formatDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<BaseLayout
  title={`${THOUGHTS.brand} | Arun Setty`}
  description={`${THOUGHTS.tagline} ${THOUGHTS.blurb}`}
>
  <section class="thoughts-hero">
    <div class="container narrow">
      <span class="eyebrow">{THOUGHTS.brand}</span>
      <h1 class="thoughts-title">{THOUGHTS.tagline}</h1>
      <p class="thoughts-blurb">{THOUGHTS.blurb}</p>
      <p class="thoughts-meta">
        <span class="thoughts-count">{total}</span>
        <span class="thoughts-count-label">{total === 1 ? "thought" : "thoughts"}</span>
        <span class="thoughts-meta-sep">·</span>
        <span class="thoughts-meta-rss">
          <a href="/rss.xml">RSS</a>
        </span>
      </p>
    </div>
  </section>

  <section class="thoughts-archive-section">
    <div class="container narrow">
      {total === 0 ? (
        <p class="thoughts-empty">
          Nothing here yet. Check back soon — or
          <a href="mailto:arunsetty1729@gmail.com">say hi</a> in the meantime.
        </p>
      ) : (
        <ol class="thoughts-archive">
          {posts.map((p, i) => {
            const num = total - 1 - i;
            return (
              <li class="archive-item">
                <a href={`/thoughts/${p.slug}`} class="archive-link">
                  <span class="archive-num">{String(num).padStart(2, "0")}.</span>
                  <div class="archive-body">
                    <h2 class="archive-title">{p.data.title}</h2>
                    <p class="archive-desc">{p.data.description}</p>
                    <div class="archive-meta">
                      <time>{formatDate(p.data.pubDate)}</time>
                      {p.data.tags.length > 0 && (
                        <>
                          <span class="archive-meta-sep">·</span>
                          <span class="archive-tags">
                            {p.data.tags.map((tag) => (
                              <span class="archive-tag">{tag}</span>
                            ))}
                          </span>
                        </>
                      )}
                    </div>
                  </div>
                </a>
              </li>
            );
          })}
        </ol>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .thoughts-hero {
    padding-top: 140px;
    padding-bottom: 24px;
  }

  .thoughts-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 12px 0 16px;
    color: var(--text-primary);
  }

  .thoughts-blurb {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--text-secondary);
    font-style: italic;
    margin: 0 0 16px;
    max-width: 60ch;
    line-height: 1.6;
  }

  .thoughts-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
    letter-spacing: 0.04em;
  }

  .thoughts-count {
    color: var(--accent-primary);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .thoughts-count-label {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .thoughts-meta-sep {
    color: var(--text-quiet);
  }

  .thoughts-meta-rss a {
    color: var(--text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
  }

  .thoughts-meta-rss a:hover {
    color: var(--accent-primary);
  }

  .thoughts-archive-section {
    padding-top: 32px;
  }

  .thoughts-archive {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--rule-color);
  }

  .archive-item {
    border-bottom: 1px solid var(--rule-color);
  }

  .archive-link {
    display: flex;
    gap: 24px;
    align-items: baseline;
    padding: 28px 0;
    text-decoration: none;
    color: inherit;
    transition: padding 0.18s ease;
  }

  .archive-link:hover {
    padding-left: 8px;
  }

  .archive-link:hover .archive-title {
    color: var(--accent-primary);
  }

  .archive-num {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    min-width: 40px;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  .archive-body { flex: 1; min-width: 0; }

  .archive-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 8px;
    letter-spacing: -0.015em;
    line-height: 1.25;
    transition: color 0.18s ease;
  }

  .archive-desc {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .archive-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    letter-spacing: 0.04em;
  }

  .archive-meta-sep {
    color: var(--text-quiet);
  }

  .archive-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .archive-tag {
    color: var(--text-muted);
  }

  .archive-tag::before {
    content: "#";
    color: var(--text-quiet);
    margin-right: 1px;
  }

  .thoughts-empty {
    color: var(--text-secondary);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.7;
    padding: 32px 0;
  }

  .thoughts-empty a {
    color: var(--accent-primary);
  }
</style>
