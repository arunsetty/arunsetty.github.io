---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
import { THOUGHTS } from "../../consts";

const posts = (await getCollection("thoughts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const count = posts.length;
const countLabel = count === 1 ? "thought" : "thoughts";
---

<BaseLayout
  title={`${THOUGHTS.brand} | Arun Setty`}
  description={`${THOUGHTS.tagline} ${THOUGHTS.blurb}`}
>
  <!-- Cinematic hero -->
  <section class="hero-section cinematic-only">
    <div class="container">
      <span class="page-label">{THOUGHTS.brand}</span>
      <h1 class="gradient-text page-title">{THOUGHTS.tagline}</h1>
      <p class="page-desc">{THOUGHTS.blurb}</p>
      <p class="thought-count">
        <span class="thought-count-num">{count}</span>
        <span class="thought-count-label">{countLabel} and counting</span>
      </p>
    </div>
  </section>

  <!-- Terminal hero -->
  <section class="hero-section terminal-only">
    <div class="container">
      <span class="page-label">{THOUGHTS.brand}</span>
      <h1 class="gradient-text page-title">$ ls -lt ./thoughts/</h1>
      <p class="page-desc">// {THOUGHTS.tagline.toLowerCase()}</p>
      <p class="thought-count terminal-count">
        // total: <span class="thought-count-num">{count}</span> {countLabel}
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      {count === 0 ? (
        <div class="empty-state glass-card">
          <p class="cinematic-only">
            No thoughts yet. Check back soon — or
            <a href={`mailto:arunsetty1729@gmail.com?subject=Hi`}>say hi</a> in
            the meantime.
          </p>
          <p class="terminal-only">
            <span class="t-comment"># total: 0 thoughts</span><br />
            <span class="t-comment"># nothing here yet — check back soon</span>
          </p>
        </div>
      ) : (
        <div class="posts-grid">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.slug}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section {
    padding-top: 140px;
    padding-bottom: 40px;
  }

  .page-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 12px;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 20px;
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 500px;
    line-height: 1.7;
    margin: 0 0 16px;
  }

  .thought-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .thought-count-num {
    color: var(--accent-primary);
    font-weight: 600;
    font-size: 1.05rem;
  }

  .thought-count-label {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
  }

  .terminal-count {
    color: #009922;
  }

  .terminal-count .thought-count-num {
    color: #00ff41;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 700px;
  }

  .empty-state {
    padding: 32px;
    max-width: 700px;
  }

  .empty-state p {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.7;
  }

  .empty-state a {
    color: var(--accent-primary);
  }

  .t-comment {
    color: #009922;
  }

  .terminal-only { display: none; }
  :global([data-theme="terminal"]) .cinematic-only { display: none; }
  :global([data-theme="terminal"]) .terminal-only { display: block; }
</style>
