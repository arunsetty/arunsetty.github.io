---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("thoughts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Estimate reading time
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 250));
---

<BaseLayout title={`${post.data.title} | Arun Setty`} description={post.data.description}>
  <article class="blog-article">
    <div class="container">
      <!-- Cinematic header -->
      <div class="cinematic-only">
        <a href="/thoughts" class="back-link">&larr; All Thoughts</a>

        <header class="blog-header">
          <div class="blog-meta">
            <time>{formattedDate}</time>
            <span class="separator">&middot;</span>
            <span>{readingTime} min read</span>
          </div>

          <h1 class="gradient-text blog-title">{post.data.title}</h1>
          <p class="blog-desc">{post.data.description}</p>

          {post.data.tags.length > 0 && (
            <div class="blog-tags">
              {post.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </header>
      </div>

      <!-- Terminal header -->
      <div class="terminal-only">
        <a href="/thoughts" class="back-link">$ cd ../thoughts/</a>

        <header class="blog-header">
          <div class="terminal-file-meta">
            <span class="t-comment">---</span>
            <div class="t-meta-line"><span class="t-key">title:</span> <span class="t-val">"{post.data.title}"</span></div>
            <div class="t-meta-line"><span class="t-key">date:</span> <span class="t-val">{formattedDate}</span></div>
            <div class="t-meta-line"><span class="t-key">reading_time:</span> <span class="t-val">{readingTime} min</span></div>
            {post.data.tags.length > 0 && (
              <div class="t-meta-line"><span class="t-key">tags:</span> <span class="t-val">[{post.data.tags.join(", ")}]</span></div>
            )}
            <span class="t-comment">---</span>
          </div>

          <h1 class="gradient-text blog-title">$ cat ./thoughts/{post.slug}.md</h1>
        </header>
      </div>

      <div class="blog-content">
        <Content />
      </div>

      <footer class="blog-footer">
        <a href="/thoughts" class="back-link">
          <span class="cinematic-only">&larr; Back to all thoughts</span>
          <span class="terminal-only">$ cd ../thoughts/</span>
        </a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    padding-top: 120px;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 40px;
    transition: color 0.3s ease;
  }

  .back-link:hover {
    color: var(--accent-primary);
  }

  .blog-header {
    margin-bottom: 60px;
    max-width: 700px;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .separator {
    color: var(--border-color);
  }

  .blog-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .blog-desc {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0 0 20px;
  }

  .blog-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    padding: 2px 12px;
    border-radius: 4px;
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--accent-primary);
    border: 1px solid var(--border-color);
  }

  .blog-content {
    max-width: 700px;
  }

  .blog-content :global(h2) {
    font-size: 1.5rem;
    color: var(--text-primary);
    margin: 56px 0 16px;
    font-weight: 600;
  }

  .blog-content :global(h3) {
    font-size: 1.2rem;
    color: var(--text-primary);
    margin: 40px 0 12px;
  }

  .blog-content :global(p) {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.9;
    margin: 0 0 24px;
  }

  .blog-content :global(blockquote) {
    border-left: 2px solid var(--accent-primary);
    padding-left: 20px;
    margin: 32px 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .blog-content :global(ul),
  .blog-content :global(ol) {
    padding-left: 24px;
    margin: 0 0 24px;
  }

  .blog-content :global(li) {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.9;
    margin-bottom: 8px;
  }

  .blog-content :global(code) {
    background: var(--bg-card);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.85rem;
    color: var(--accent-primary);
  }

  .blog-content :global(pre) {
    background: var(--bg-secondary) !important;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 20px;
    overflow-x: auto;
    margin: 32px 0;
  }

  .blog-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .blog-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 48px 0;
  }

  .blog-content :global(em) {
    color: var(--text-muted);
  }

  .blog-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .blog-footer {
    margin-top: 80px;
    padding-top: 32px;
    border-top: 1px solid var(--border-color);
  }

  /* Theme visibility toggling */
  .terminal-only { display: none; }
  :global([data-theme="terminal"]) .cinematic-only { display: none; }
  :global([data-theme="terminal"]) .terminal-only { display: block; }
  :global([data-theme="terminal"]) span.terminal-only { display: inline; }
  :global([data-theme="terminal"]) span.cinematic-only { display: none; }

  /* Terminal meta */
  .terminal-file-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.8;
    margin-bottom: 24px;
  }

  .t-comment {
    color: #009922;
    opacity: 0.6;
    display: block;
  }

  .t-meta-line {
    padding-left: 4px;
  }

  .t-key {
    color: #00cc33;
  }

  .t-val {
    color: #00ff41;
  }

  :global([data-theme="terminal"]) .tag {
    border-radius: 0;
  }

  :global([data-theme="terminal"]) .blog-content :global(pre) {
    border-radius: 0;
  }

  :global([data-theme="terminal"]) .blog-content :global(code) {
    border-radius: 0;
  }

  :global([data-theme="terminal"]) .blog-content :global(blockquote) {
    border-left-color: #00ff41;
  }
</style>
