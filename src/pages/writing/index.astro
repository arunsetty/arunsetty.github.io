---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Writing | Arun Setty" description="Essays on software, philosophy, and building things that matter.">
  <!-- Cinematic hero -->
  <section class="hero-section cinematic-only">
    <div class="container">
      <span class="page-label">Writing</span>
      <h1 class="gradient-text page-title">Thoughts & Essays</h1>
      <p class="page-desc">
        On building software, philosophy, and the spaces in between.
        Slow thinking in a fast world.
      </p>
    </div>
  </section>

  <!-- Terminal hero -->
  <section class="hero-section terminal-only">
    <div class="container">
      <span class="page-label">Writing</span>
      <h1 class="gradient-text page-title">$ ls -la ./writing/</h1>
      <p class="page-desc">
        // on building software, philosophy, and the spaces in between
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="posts-grid">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.slug}
          />
        ))}
      </div>

      {posts.length === 0 && (
        <p style="color: var(--text-muted); font-family: var(--font-mono); font-size: 0.9rem;">
          No posts yet. Check back soon.
        </p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section {
    padding-top: 140px;
    padding-bottom: 40px;
  }

  .page-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 12px;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 20px;
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 500px;
    line-height: 1.7;
    margin: 0;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 700px;
  }

  .terminal-only { display: none; }
  :global([data-theme="terminal"]) .cinematic-only { display: none; }
  :global([data-theme="terminal"]) .terminal-only { display: block; }
</style>
