---
import BaseLayout from "../layouts/BaseLayout.astro";
import Timeline from "../components/Timeline.tsx";
---

<BaseLayout
  title="Journey | Arun Setty"
  description="Eight years of building software — from mentoring students to AI to fullstack development to no-code platforms."
>
  <article class="journey">
    <div class="container narrow">
      <header class="journey-header">
        <span class="eyebrow">Journey</span>
        <h1 class="journey-title">Where I've been</h1>
        <p class="journey-lede">
          Eight years across mentoring, AI, fullstack, and now no-code. Each
          role taught me something different about building software people
          actually use.
        </p>
      </header>

      <div class="journey-rule"></div>

      <Timeline client:visible />

      <div class="journey-footer">
        <a href="/resume.pdf" target="_blank" class="journey-link">Download resume →</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .journey {
    padding-top: 120px;
    padding-bottom: 80px;
  }

  .journey-header {
    margin-bottom: 28px;
  }

  .journey-title {
    font-family: var(--font-sans);
    font-size: clamp(2.2rem, 5.5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 12px 0 16px;
    color: var(--text-primary);
  }

  .journey-lede {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-style: italic;
    margin: 0;
    max-width: 60ch;
  }

  .journey-rule {
    height: 1px;
    background: var(--rule-color);
    margin: 40px 0;
  }

  .journey-footer {
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--rule-color);
  }

  .journey-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-primary);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid rgba(232, 182, 88, 0.4);
    letter-spacing: 0.04em;
  }

  .journey-link:hover {
    border-bottom-color: var(--accent-primary);
  }
</style>
