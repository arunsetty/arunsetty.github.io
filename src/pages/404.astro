---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404: Page Not Found | Arun Setty"
  description="The page you're looking for doesn't exist."
>
  <article class="four-oh-four">
    <div class="container narrow">
      <span class="eyebrow">Error · 404</span>
      <h1 class="title">Lost in the void</h1>
      <p class="lede">
        The page you're looking for doesn't exist, or it once did and has
        moved on. Either way, let's get you somewhere real.
      </p>

      <div class="links">
        <a href="/" class="link">Take me home →</a>
        <a href="/thoughts" class="link">Read my thoughts →</a>
        <a href="/work" class="link">View my work →</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .four-oh-four {
    padding-top: 140px;
    padding-bottom: 120px;
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
    margin: 12px 0 20px;
    color: var(--text-primary);
  }

  .lede {
    font-family: var(--font-serif);
    font-size: 1.18rem;
    color: var(--text-secondary);
    line-height: 1.65;
    font-style: italic;
    margin: 0 0 40px;
    max-width: 55ch;
  }

  .links {
    display: flex;
    gap: 18px;
    flex-wrap: wrap;
  }

  .link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-primary);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid rgba(184, 54, 45, 0.4);
    letter-spacing: 0.04em;
  }

  .link:hover {
    border-bottom-color: var(--accent-primary);
  }
</style>
