---
import { ViewTransitions } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ScrollProgress from "../components/ScrollProgress.tsx";
import { SITE, SOCIAL } from "../consts";

// Self-hosted fonts (bundled by Vite). JS-side imports so Vite
// processes the woff2 url()s and copies the files into dist/.
import "@fontsource-variable/fraunces/opsz.css";
import "@fontsource-variable/fraunces/opsz-italic.css";
import "@fontsource-variable/newsreader/opsz.css";
import "@fontsource-variable/newsreader/opsz-italic.css";
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";

// Preload the Latin opsz variants — the masthead and body are
// rendered in these on every page; preloading lets the browser
// fetch them in parallel with HTML parsing instead of after CSS.
import frauncesLatinNormal from "@fontsource-variable/fraunces/files/fraunces-latin-opsz-normal.woff2?url";
import frauncesLatinItalic from "@fontsource-variable/fraunces/files/fraunces-latin-opsz-italic.woff2?url";
import newsreaderLatinNormal from "@fontsource-variable/newsreader/files/newsreader-latin-opsz-normal.woff2?url";
import newsreaderLatinItalic from "@fontsource-variable/newsreader/files/newsreader-latin-opsz-italic.woff2?url";

import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = SITE.description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://arunsetty.github.io");
const ogImage = new URL(SITE.image, Astro.site ?? "https://arunsetty.github.io").toString();

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.name,
  givenName: "Arun",
  additionalName: "Setty",
  familyName: "Kodavali",
  alternateName: ["A.S.K", "Arun Setty"],
  description: `${SITE.titles.join(", ")}. ${SITE.motto}`,
  url: SITE.url,
  email: `mailto:${SITE.email}`,
  jobTitle: "Storyteller, tinkerer, engineer",
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Indian Institute of Technology, Bombay",
  },
  sameAs: SOCIAL.filter((s) => s.icon !== "email").map((s) => s.url),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f5efe1" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon — A·S·K mark -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#b8362d" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Preload critical fonts so they fetch in parallel with HTML
         parsing rather than after CSS resolves. -->
    <link rel="preload" href={frauncesLatinNormal} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={frauncesLatinItalic} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={newsreaderLatinNormal} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={newsreaderLatinItalic} as="font" type="font/woff2" crossorigin />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Fonts are self-hosted via Fontsource (bundled at build time)
         and imported in global.css. No CDN round-trip needed. -->


    <!-- RSS feed (placeholder, may be added later) -->
    <link rel="alternate" type="application/rss+xml" title="Ephemeral Thoughts" href="/rss.xml" />

    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <ScrollProgress client:load />
    <Nav />
    <main transition:animate="fade">
      <slot />
    </main>
    <Footer />
  </body>
</html>
